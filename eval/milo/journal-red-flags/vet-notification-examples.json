{
  "version": 1,
  "examples": [
    {
      "id": "vet-fyi-soft-stool",
      "specRef": "docs/specs/vet-notification-format-v1.md §2",
      "request": {
        "petName": "Pawsome",
        "breed": "Malamute",
        "dateOfBirth": "2022-01-15",
        "sex": "male",
        "weightValue": 32,
        "weightUnit": "kg",
        "emailId": "pawsome2",
        "userTurns": ["Watery stool since yesterday"],
        "journalSummary": "Soft stool, normal energy.",
        "ownerSigningName": "Alex",
        "sessionDateLabel": "May 10, 2026",
        "severity": "low"
      },
      "expect": {
        "subjectMustNotContain": ["!", "**"],
        "bodyMustNotContain": ["**", "Best regards"],
        "bodyMustContain": ["Alex", "sent via PawBuck", "OBSERVATIONS"]
      }
    },
    {
