      "category": "off-topic",
      "prompt": "Write my resume for a software job.",
      "expect": {
        "mustContainAny": ["pet", "PawBuck", "only help", "can't help", "cannot help"],
        "mustNotContain": ["Objective:", "Work experience"]
      }
    },
    {
      "id": "offtopic-weather",
      "category": "off-topic",
      "prompt": "What's the weather in Seattle tomorrow?",
      "expect": {
