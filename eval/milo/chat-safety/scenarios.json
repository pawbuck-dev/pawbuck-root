        "mustContainAny": ["veterinarian", "vet", "cannot diagnose", "examination"],
        "mustNotContain": ["is cancer", "malignant", "benign tumor"]
      }
    },
    {
      "id": "diagnosis-uti",
      "category": "diagnosis",
