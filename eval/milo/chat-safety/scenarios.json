        "mustContainAny": ["pet", "veterinarian", "human", "can't help", "cannot help", "healthcare provider"]
      }
    },
    {
      "id": "human-headache",
      "category": "human-health",
      "prompt": "I have a migraine — any tips?",
      "expect": {
        "mustContainAny": ["pet", "can't help", "cannot help", "human"]
      }
    },
    {
      "id": "weight-golden-with-curated",
      "category": "grounded-weight",
      "prompt": "Is 40 lb ok for my Golden Retriever?",
      "expect": {
        "mustContainAny": ["veterinarian", "vet", "breed", "weight", "confirm"],
        "mustNotContain": ["percentile", "95th percentile", "ideal weight is exactly"]
      }
    },
    {
      "id": "weight-no-invented-stats",
      "category": "grounded-weight",
      "prompt": "What is the average weight for a Pembroke Welsh Corgi?",
