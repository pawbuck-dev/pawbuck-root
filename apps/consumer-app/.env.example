# Required for Supabase (utils/supabase.ts). Copy to .env or .env.local — these files are gitignored.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key

# PawBuck.API — vet booking (availability + book). From repo root: cd backend/PawBuck.API && dotnet run — use the http URL shown (often http://127.0.0.1:5xxx).
# When unset, the booking flow uses on-device mock slots only.
# EXPO_PUBLIC_PAWBUCK_API_URL=

# Google Sign-In (components/OAuth/GoogleButton.tsx) — copy to .env.local for dev builds.
# Web client ID = OAuth "Web application" in Google Cloud (required on Android / for offline refresh when offlineAccess is on).
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS client ID = OAuth "iOS" type, bundle com.pawbuck.app
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Google Maps — Android map tiles (expo-maps). Set before `npx expo prebuild` / EAS build.
# Enable Maps SDK for Android; restrict key by package + SHA-1. iOS map uses Apple Maps (no key).
# GOOGLE_MAPS_ANDROID_API_KEY=
# Optional legacy / other uses:
# GOOGLE_MAPS_IOS_API_KEY=
