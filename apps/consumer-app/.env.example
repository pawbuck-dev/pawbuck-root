# Required for Supabase (utils/supabase.ts). Copy to .env or .env.local — these files are gitignored.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key

# Scripts only (e.g. seed-documentation-rag.ts) — from Supabase Dashboard → Settings → API → service_role. Never ship in the app or commit.
# Use this exact name (not EXPO_SUPABASE_*): the seed script reads SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_SERVICE_ROLE_KEY=
# GOOGLE_GEMINI_API_KEY=   (script also accepts EXPO_GOOGLE_GEMINI_API_KEY as fallback; prefer GOOGLE_* for secrets.)

# PawBuck.API — vet booking + Milo chat. From repo: cd backend/PawBuck.API && dotnet run — match
# Properties/launchSettings.json applicationUrl (often http://127.0.0.1:5289). iOS Simulator can use 127.0.0.1.
# When unset, Milo chat errors and booking may use mock slots only.
EXPO_PUBLIC_PAWBUCK_API_URL=http://127.0.0.1:5289

# Google Sign-In (components/OAuth/GoogleButton.tsx) — copy to .env.local for dev builds.
# Web client ID = OAuth "Web application" in Google Cloud (required on Android / for offline refresh when offlineAccess is on).
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS client ID = OAuth "iOS" type, bundle com.pawbuck.app
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Google Maps — Android map tiles (expo-maps). Set before `npx expo prebuild` / EAS build.
# Enable Maps SDK for Android; restrict key by package + SHA-1. iOS map uses Apple Maps (no key).
# GOOGLE_MAPS_ANDROID_API_KEY=
# Optional legacy / other uses:
# GOOGLE_MAPS_IOS_API_KEY=

# Dev only: treat user as premium for subscription-gated UI (never enable in production builds).
# EXPO_PUBLIC_SUBSCRIPTION_DEV_PREMIUM=true

# Monetization kill-switch (default OFF = free launch; everyone treated as Family).
# Set to true when App Store Connect / RevenueCat billing is ready — rebuild native app after changing.
# EXPO_PUBLIC_MONETIZATION_ENABLED=true

# RevenueCat — see docs/REVENUECAT.md
# Dev (Test Store): test_xxxxxxxx  |  Production: appl_ / goog_ keys
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=test_xxxxxxxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=test_xxxxxxxx
