# Required for Supabase (utils/supabase.ts). Copy to .env or .env.local — these files are gitignored.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key

# Optional: Google Sign-In (components/OAuth/GoogleButton.tsx)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Google Maps (react-native-maps + PROVIDER_GOOGLE) — set before `npx expo prebuild` / EAS build.
# Enable Maps SDK for iOS & Android in Google Cloud; restrict keys by bundle ID / package + SHA-1.
# GOOGLE_MAPS_IOS_API_KEY=
# GOOGLE_MAPS_ANDROID_API_KEY=
